{
    "modules": [
        "/plugins/DevUtils/Cursor.js"
    ],
    "preloads": [
        "var cur = new Cursor();"
    ],
    "commands": [
        {
            "command": "0",
            "handler": "cur.goLineTop(0, true);",
            "description": ""
        },
        {
            "command": "\\^",
            "handler": "cur.goLineTop(0, false);",
            "description": ""
        },
        {
            "command": "\\$",
            "handler": "cur.goLineEnd();",
            "description": ""
        },

        {
            "command": "gg",
            "handler": "cur.goFileTop();",
            "description": ""
        },
        {
            "command": "G",
            "handler": "cur.goFileEnd();",
            "description": ""
        },
        {
            "command": "(\\d+)gg",
            "handler": [
                "var line = Number(matches[1]);",
                "cur.move(line, cur.getCol());"
            ],
            "description": ""
        },
        {
            "command": "(\\d+)G",
            "handler": [
                "var line = Number(matches[1]);",
                "cur.move(line, cur.getCol());"
            ],
            "description": ""
        },
        {
            "command": ":(\\d+)",
            "handler": [
                "var line = Number(matches[1]);",
                "cur.move(line, cur.getCol());"
            ],
            "description": ""
        },
        {
            "command": "/(.+)",
            "handler": [
                "var word = matches[1];",
                "cur.searchNext(word);"
            ],
            "description": ""
        },
        {
            "command": "\\?(.+)",
            "handler": [
                "var word = matches[1];",
                "cur.searchPrev(word);"
            ],
            "description": ""
        },
        {
            "command": "\\*",
            "handler": [
                "var word = cur.getCurrentWord();",
                "cur.searchNext(word);"
            ],
            "description": ""
        },
        {
            "command": "#",
            "handler": [
                "var word = cur.getCurrentWord();",
                "cur.searchPrev(word);"
            ],
            "description": ""
        },

        {
            "command": "%",
            "handler": "cur.goMatchedPair();",
            "description": ""
        },

        {
            "command": "dd",
            "handler": "cur.deleteCurrentLine();",
            "description": ""
        },
        {
            "command": "D",
            "handler": [
                "var tmpCur = cur.getProperty();",
                "cur.escape();",
                "cur.goLineEnd(1);",
                "cur.deleteBack();",
                "cur.loadProperty(tmpCur);"
            ],
            "description": ""
        },
        {
            "command": "diw",
            "handler": "cur.deleteCurrentWord();",
            "description": ""
        },
        {
            "command": ":(\\d+)d",
            "handler": [
                "var line = Number(matches[1]);",
                "cur.deleteLine(line);"
            ],
            "description": ""
        },
        {
            "command": "d0",
            "handler": "cur.deleteCurrentLineToStart();",
            "description": ""
        },
        {
            "command": "d\\^",
            "handler": "cur.deleteCurrentLineToStart();",
            "description": ""
        },
        {
            "command": "d\\$",
            "handler": "cur.deleteCurrentLineToEnd();",
            "description": ""
        },
        {
            "command": "dgg",
            "handler": [
                "cur.goFileTop(1);",
                "cur.deleteBack();"
            ],
            "description": ""
        },
        {
            "command": "dG",
            "handler": [
                "cur.goFileEnd(1);",
                "cur.deleteBack();"
            ],
            "description": ""
        },

        {
            "command": "u",
            "handler": "cur.undo();",
            "description": ""
        },
        {
            "command": "r",
            "handler": "cur.redo();",
            "description": ""
        },

        {
            "command": "y",
            "handler": "cur.copy();",
            "description": ""
        },
        {
            "command": "yy",
            "handler": [
                "var tmpCur = cur.getProperty();",
                "cur.goLineTop(0);",
                "cur.goLineEnd(1);",
                "Editor.Copy(0);",
                "cur.loadProperty(tmpCur);"
            ],
            "description": ""
        },
        {
            "command": "y",
            "handler": "cur.copy();",
            "description": ""
        }
    ],
    "externals" : [
        "/plugins/CommentOut/CommandListenerConfig.json"
    ]
}
