{
    "modules": [
        "/plugins/DevUtils/Cursor.js"
    ],
    "preload": [
        "var cur = new Cursor();"
    ],
    "commands": {
            "0": "cur.goLineTop();",
            "\\^": "cur.goLineTop();",
            "\\$": "cur.goLineEnd();",
            "gg": "cur.goFileTop();",
            "G": "cur.goFileEnd();",
            "w": "cur.selectCurrentWord();",

            "dd": "cur.deleteCurrentLine();",
            "dw": "cur.deleteCurrentWord();",
            "d0": "cur.deleteCurrentLineToStart();",
            "d\\$": "cur.deleteCurrentLineToEnd();",
            "dgg": [
                "cur.goFileTop(1);",
                "cur.deleteBack();"
            ],
            "dG": [
                "cur.goFileEnd(1);",
                "cur.deleteBack();"
            ],

            "u": "cur.undo();",
            "r": "cur.redo();",

            "y": "Editor.Copy(0);",
            "yy": [
                "var tmpCur = cur.getProperty();",
                "cur.goLineTop(0);",
                "cur.goLineEnd(1);",
                "Editor.Copy(0);",
                "cur.loadProperty(tmpCur);"
            ],
            "p": "Editor.Paste(0);"
    },
    "externals" : []
}
