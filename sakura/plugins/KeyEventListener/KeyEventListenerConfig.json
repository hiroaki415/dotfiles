{
    "modules": [
        "/plugins/KeyEventListener/src/FormatEnter.js"
    ],
    "preloads": [
        "var cur = new Cursor();"
    ],
    "handlers": {
        "\r": "FormatEnter();",
        "(": [
            "cur.insertText(')');",
            "cur.moveLeft();"
        ],
        ")": "if (cur.getNextChar() === ')') { cur.deleteWithoutBack(); }",
        "[": [
            "cur.insertText(']');",
            "cur.moveLeft();"
        ],
        "]": "if (cur.getNextChar() === ']') { cur.deleteWithoutBack(); };",
        "{": [
            "cur.insertText('}');",
            "cur.moveLeft();"
        ],
        "}": "if (cur.getNextChar() === '}') { cur.deleteWithoutBack(); }",
        "<:diisable": [
            "cur.insertText('>');",
            "cur.moveLeft();"
        ],
        ">:diisable": "if (cur.getNextChar() === '>') { cur.deleteWithoutBack(); }",
        "'": [
            "cur.insertText('\\'');",
            "cur.moveLeft();"
        ],
        "\"": [
            "cur.insertText('\"');",
            "cur.moveLeft();"
        ]
    },
    "externals": []
}
