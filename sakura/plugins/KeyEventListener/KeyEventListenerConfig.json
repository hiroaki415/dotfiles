{
    "modules": [
        "/plugins/DevUtils/Decorator.js",
        "/plugins/KeyEventListener/FormatEnter.js",
        "/plugins/KeyEventListener/AutoPairs.js"
    ],
    "preloads": [
        "var cur = new Cursor();"
    ],
    "handlers": {
        "\r":  "CommandDecorator(FormatEnter)();",
        "(":  "CommandDecorator(AutoPairs)(')');",
        ")":  "CommandDecorator(AutoPairsClosing)(')');",
        "[":  "CommandDecorator(AutoPairs)(']');",
        "]":  "CommandDecorator(AutoPairsClosing)(']');",
        "{":  "CommandDecorator(AutoPairs)('}');",
        "}":  "CommandDecorator(AutoPairsClosing)('}');",
        "<:diisable":  "CommandDecorator(AutoPairs)('>');",
        ">:diisable":  "CommandDecorator(AutoPairsClosing)('>');",
        "'":  "CommandDecorator(AutoPairs)('\\'');",
        "\"":  "CommandDecorator(AutoPairs)('\"');"
    },
    "externals" : []
}
