{
    "modules": [
        "/plugins/KeyEventListener/src/FormatEnter.js",
        "/plugins/KeyEventListener/src/GetXmlTagClosing.js"
    ],
    "preloads": [
        "var cur = new Cursor();"
    ],
    "handlers": {
        "\r": "FormatEnter();",
        "(": [
            "cur.insertText(')');",
            "cur.moveLeft();"
        ],
        ")": "if (cur.getNextChar() === ')') { cur.deleteWithoutBack(); }",
        "[": [
            "cur.insertText(']');",
            "cur.moveLeft();"
        ],
        "]": "if (cur.getNextChar() === ']') { cur.deleteWithoutBack(); };",
        "{": [
            "cur.insertText('}');",
            "cur.moveLeft();"
        ],
        "}": "if (cur.getNextChar() === '}') { cur.deleteWithoutBack(); }",
        "<:diisable": [
            "cur.insertText('>');",
            "cur.moveLeft();"
        ],
        ">": [
            "var lineTextBefore = cur.getLineTextBeforeCursor();",
            "var tagClosing = GetXmlTagClosing(lineTextBefore);",
            "if (tagClosing) { cur.insertText(tagClosing); cur.move(cur.getLine(), cur.getCol() - tagClosing.length); }"
        ],
        "'": [
            "cur.insertText('\\'');",
            "cur.moveLeft();"
        ],
        "\"": [
            "cur.insertText('\"');",
            "cur.moveLeft();"
        ]
    },
    "externals": []
}
